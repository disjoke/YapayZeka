PORT=3000
NODE_ENV=production
JWT_SECRET=ekinciler-super-secret-change-in-production
OPENAI_API_KEY=sk-your-openai-key
CORS_ORIGIN=*
PUBLIC_API_URL=https://ekinciler-api.onrender.com

# Meta (Facebook/Instagram) — developers.facebook.com
META_APP_ID=
META_APP_SECRET=
# Simülatör: aşağıdaki satırı kullanın
# Geliştirme:
# META_REDIRECT_URI=http://127.0.0.1:3000/social/oauth/meta/callback
# Canlı (App Store):
META_REDIRECT_URI=https://ekinciler-api.onrender.com/social/oauth/meta/callback
# Gerçek iPhone (Mac ile aynı Wi‑Fi): Mac IP'nizi yazın, örn:
# META_REDIRECT_URI=http://192.168.1.10:3000/social/oauth/meta/callback
META_APP_REDIRECT=ekinciler://oauth/meta

# WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=ekinciler-verify

# Replicate (video AI - opsiyonel)
REPLICATE_API_TOKEN=
